# Project-local Codex MCP configuration example for DBHub.
# Copy this file to: .codex/config.toml
# Do not place credentials in this file.

[mcp_servers.dbhub]
command = "npx"
args = [
  "-y",
  "@bytebase/dbhub@latest",
  "--transport",
  "stdio",
  "--config",
  "mcp/database/dbhub.local.toml",
]
