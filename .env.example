# Local PostgreSQL
LOCAL_POSTGRES_HOST=your_local_postgres_host
LOCAL_POSTGRES_PORT=your_local_postgres_port
LOCAL_POSTGRES_DB=your_local_postgres_db
LOCAL_POSTGRES_USER=your_local_postgres_user
LOCAL_POSTGRES_PASSWORD=your_local_postgres_password

# Local MySQL/MariaDB
LOCAL_MYSQL_HOST=your_local_mysql_host
LOCAL_MYSQL_PORT=your_local_mysql_port
LOCAL_MYSQL_DB=your_local_mysql_db
LOCAL_MYSQL_USER=your_local_mysql_user
LOCAL_MYSQL_PASSWORD=your_local_mysql_password

# Production (read-only account only)
PROD_DB_HOST=your_prod_host
PROD_DB_PORT=your_prod_port
PROD_DB_NAME=your_prod_database
PROD_DB_READONLY_USER=your_prod_readonly_user
PROD_DB_READONLY_PASSWORD=your_prod_readonly_password
